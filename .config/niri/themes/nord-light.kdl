layout {
    insert-hint {
        color "#b48ead"
    }

    border {
        active-color "#b48ead"
        inactive-color "#a5abb6"
    }
}

overview {
    backdrop-color "#a5abb6"
}

layer-rule {
    match namespace="^waybar$"
    match namespace="eww-bar"
    shadow {
        color "#0004"
    }
}

layer-rule {
    match namespace="rofi"
    shadow {
        color "#0004"
    }
}

recent-windows {
    highlight {
        active-color "#b48ead"
    }
}
